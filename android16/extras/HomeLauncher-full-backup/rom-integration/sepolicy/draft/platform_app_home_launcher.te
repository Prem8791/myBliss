# Deferred draft only. Do not enable before first boot of the ROM-bundled launcher.
#
# Previous standalone runtime evidence showed platform_app denials for:
# - /proc/stat labeled proc_stat
# - /sys/class/thermal/.../temp labeled sysfs_thermal
#
# Re-collect AVCs after HomeLauncher is baked into /system/priv-app before enabling these.

allow platform_app proc_stat:file r_file_perms;
allow platform_app sysfs_thermal:file r_file_perms;
